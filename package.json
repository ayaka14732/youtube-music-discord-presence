{
  "name": "youtube-music-discord-presence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run build:extension && pnpm run build:native",
    "build:extension": "node scripts/build-extension.mjs",
    "build:native": "node scripts/build-native-host.mjs",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@types/chrome": "0.2.2",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
