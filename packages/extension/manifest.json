{
  "manifest_version": 3,
  "name": "YouTube Music Discord Presence",
  "version": "0.1.0",
  "description": "Shows the current YouTube Music track as Discord Rich Presence.",
  "key": "",
  "minimum_chrome_version": "120",
  "permissions": ["alarms", "nativeMessaging", "storage"],
  "host_permissions": ["https://music.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Music Discord Presence"
  }
}
